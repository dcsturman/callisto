# Backend server URL
VITE_CALLISTO_BACKEND=http://localhost:30000

# Node server URL (for OAuth redirect)
VITE_NODE_SERVER=http://localhost:3000

# Google OAuth Client ID
VITE_GOOGLE_OAUTH_CLIENT_ID=your-client-id-here

# Sentry (frontend project). Leave VITE_SENTRY_DSN empty to disable client-side
# error reporting. VITE_SENTRY_ENVIRONMENT tags events so dev runs can be
# filtered out of canary/production dashboards.
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development

